    {
      "id": "eng-subject-predicate",
      "title": "Subject and Predicate",
      "emoji": "\ud83d\udd0d",
      "term": "first",
      "month": "April",
      "skills": [
        {
          "id": "eng-subpred-basic",
          "title": "Finding subject and predicate",
          "lessons": [
            {
              "id": "eng-subpred-1",
              "title": "Who does what \u2014 subject and predicate",
              "type": "story",
              "character": "lila",
              "story": "Lila says: 'Every sentence has two parts! The SUBJECT tells us WHO or WHAT the sentence is about. The PREDICATE tells us WHAT the subject does.' Example: 'The owl reads books.' \u2014 SUBJECT: The owl. PREDICATE: reads books.",
              "game": {
                "type": "drag_match",
                "question": "Match each sentence to its subject!",
                "pairs": [
                  {
                    "item": "The children play.",
                    "match": "The children"
                  },
                  {
                    "item": "Birds sing sweetly.",
                    "match": "Birds"
                  },
                  {
                    "item": "Max eats bamboo.",
                    "match": "Max"
                  },
                  {
                    "item": "The sun shines bright.",
                    "match": "The sun"
                  }
                ],
                "hint": "The subject is who or what the sentence is about!"
              },
              "quiz": [
                {
                  "q": "In 'The dog barks loudly.' \u2014 what is the subject?",
                  "options": [
                    "barks",
                    "loudly",
                    "The dog",
                    "barks loudly"
                  ],
                  "correct": 2
                },
                {
                  "q": "In 'Lila reads books.' \u2014 what is the predicate?",
                  "options": [
                    "Lila",
                    "reads books",
                    "books",
                    "Lila reads"
                  ],
                  "correct": 1
                },
                {
                  "q": "The PREDICATE of a sentence tells us ______.",
                  "options": [
                    "who it is about",
                    "what the subject does",
                    "the name",
                    "nothing"
                  ],
                  "correct": 1
                }
              ],
              "rewards": {
                "stars": 3,
                "coins": 12,
                "badge": null
              }
            }
          ]
        }
      ]
