{
  "world": "story",
  "title": "Story Forest",
  "character": "lila",
  "color": "#43A047",
  "bgColor": "#E8F5E9",
  "description": "Lila the Owl teaches English grammar and reading!",
  "topics": [
    {
      "id": "eng-sentence",
      "title": "The Sentence",
      "emoji": "✍️",
      "term": "first",
      "month": "April",
      "skills": [
        {
          "id": "eng-sentence-what",
          "title": "What is a sentence?",
          "lessons": [
            {
              "id": "eng-sentence-1",
              "title": "A sentence makes complete sense",
              "type": "story",
              "character": "lila",
              "story": "Lila the Owl loves reading books! She says: 'A sentence is a group of words that makes complete sense.' For example: 'The dog runs fast.' That is a sentence. But 'the dog' alone is NOT a sentence — it doesn't tell us anything complete!",
              "game": {
                "type": "tap_correct",
                "question": "Which one is a complete sentence?",
                "options": ["The big cat", "She reads every day.", "Running fast in", "Blue and green"],
                "correct": 1,
                "hint": "A sentence must make complete sense on its own!"
              },
              "quiz": [
                { "q": "A sentence always begins with a ______.", "options": ["full stop","comma","capital letter","small letter"], "correct": 2 },
                { "q": "A sentence always ends with a ______.", "options": ["comma","full stop or !","capital letter","apostrophe"], "correct": 1 },
                { "q": "Which is NOT a sentence?", "options": ["Birds can fly.","The sun is hot.","Happy little","I love books."], "correct": 2 }
              ],
              "rewards": { "stars": 3, "coins": 10, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-subject-predicate",
      "title": "Subject and Predicate",
      "emoji": "🔍",
      "term": "first",
      "month": "April",
      "skills": [
        {
          "id": "eng-subpred-basic",
          "title": "Finding subject and predicate",
          "lessons": [
            {
              "id": "eng-subpred-1",
              "title": "Who does what — subject and predicate",
              "type": "story",
              "character": "lila",
              "story": "Lila says: 'Every sentence has two parts! The SUBJECT tells us WHO or WHAT the sentence is about. The PREDICATE tells us WHAT the subject does.' Example: 'The owl reads books.' — SUBJECT: The owl. PREDICATE: reads books.",
              "game": {
                "type": "drag_match",
                "question": "Match each sentence to its subject!",
                "pairs": [
                  { "item": "The children play.", "match": "The children" },
                  { "item": "Birds sing sweetly.", "match": "Birds" },
                  { "item": "Max eats bamboo.", "match": "Max" },
                  { "item": "The sun shines bright.", "match": "The sun" }
                ],
                "hint": "The subject is who or what the sentence is about!"
              },
              "quiz": [
                { "q": "In 'The dog barks loudly.' — what is the subject?", "options": ["barks","loudly","The dog","barks loudly"], "correct": 2 },
                { "q": "In 'Lila reads books.' — what is the predicate?", "options": ["Lila","reads books","books","Lila reads"], "correct": 1 },
                { "q": "The PREDICATE of a sentence tells us ______.", "options": ["who it is about","what the subject does","the name","nothing"], "correct": 1 }
              ],
              "rewards": { "stars": 3, "coins": 12, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-noun",
      "title": "The Noun",
      "emoji": "🏷️",
      "term": "first",
      "month": "April",
      "skills": [
        {
          "id": "eng-noun-types",
          "title": "Types of nouns",
          "lessons": [
            {
              "id": "eng-noun-1",
              "title": "What is a noun?",
              "type": "story",
              "character": "lila",
              "story": "Lila the Owl asks: 'Can you name things around you?' A NOUN is a naming word! It names a person (teacher), place (Delhi), animal (owl), or thing (book). Everything you can name is a noun!",
              "game": {
                "type": "sorting",
                "question": "Sort these words into the right noun type!",
                "categories": ["Person", "Place", "Animal", "Thing"],
                "items": [
                  { "name": "doctor", "category": 0 },
                  { "name": "Mumbai", "category": 1 },
                  { "name": "elephant", "category": 2 },
                  { "name": "pencil", "category": 3 },
                  { "name": "teacher", "category": 0 },
                  { "name": "forest", "category": 1 },
                  { "name": "parrot", "category": 2 },
                  { "name": "table", "category": 3 }
                ],
                "hint": "Nouns name persons, places, animals or things!"
              },
              "quiz": [
                { "q": "Which word is a noun?", "options": ["run","beautiful","Delhi","quickly"], "correct": 2 },
                { "q": "A noun is a ______ word.", "options": ["doing","naming","describing","joining"], "correct": 1 },
                { "q": "Which is NOT a noun?", "options": ["river","jump","flower","lion"], "correct": 1 }
              ],
              "rewards": { "stars": 3, "coins": 15, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-noun-number",
      "title": "Number of Nouns",
      "emoji": "1️⃣2️⃣",
      "term": "first",
      "month": "May",
      "skills": [
        {
          "id": "eng-singular-plural",
          "title": "Singular and Plural",
          "lessons": [
            {
              "id": "eng-number-1",
              "title": "One or more than one — singular and plural",
              "type": "story",
              "character": "lila",
              "story": "Lila has one book. But she wants more! One book → two BOOKS. One is SINGULAR. More than one is PLURAL. Usually we add -s or -es to make plural. Book → Books. Box → Boxes. Watch → Watches!",
              "game": {
                "type": "drag_match",
                "question": "Match each singular noun to its plural!",
                "pairs": [
                  { "item": "cat", "match": "cats" },
                  { "item": "box", "match": "boxes" },
                  { "item": "child", "match": "children" },
                  { "item": "leaf", "match": "leaves" }
                ],
                "hint": "Most nouns add -s. Words ending in -x, -ch, -sh add -es. Some are irregular!"
              },
              "quiz": [
                { "q": "Plural of 'mango' is ______.", "options": ["mangos","mangoes","mangos'","mango's"], "correct": 1 },
                { "q": "Plural of 'mouse' is ______.", "options": ["mouses","mouse","mice","meese"], "correct": 2 },
                { "q": "One 'tooth', many ______.", "options": ["tooths","teeths","teeth","tooths"], "correct": 2 }
              ],
              "rewards": { "stars": 3, "coins": 15, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-noun-gender",
      "title": "Gender of Nouns",
      "emoji": "♂️♀️",
      "term": "first",
      "month": "July",
      "skills": [
        {
          "id": "eng-gender-basic",
          "title": "Masculine and Feminine",
          "lessons": [
            {
              "id": "eng-gender-1",
              "title": "He or She — gender of nouns",
              "type": "story",
              "character": "lila",
              "story": "Lila says: 'Nouns have gender!' MASCULINE nouns name males: boy, king, lion. FEMININE nouns name females: girl, queen, lioness. NEUTER nouns name things with no gender: table, book, stone.",
              "game": {
                "type": "drag_match",
                "question": "Match each masculine noun to its feminine!",
                "pairs": [
                  { "item": "king", "match": "queen" },
                  { "item": "tiger", "match": "tigress" },
                  { "item": "actor", "match": "actress" },
                  { "item": "prince", "match": "princess" }
                ],
                "hint": "Many feminine nouns end in -ess!"
              },
              "quiz": [
                { "q": "Feminine of 'hero' is ______.", "options": ["heroine","heros","hera","heroess"], "correct": 0 },
                { "q": "Which is a feminine noun?", "options": ["bull","ram","hen","drake"], "correct": 2 },
                { "q": "Masculine of 'mare' is ______.", "options": ["horse","stallion","pony","colt"], "correct": 1 }
              ],
              "rewards": { "stars": 3, "coins": 15, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-verb",
      "title": "The Verb",
      "emoji": "🏃",
      "term": "first",
      "month": "May",
      "skills": [
        {
          "id": "eng-verb-action",
          "title": "Action verbs",
          "lessons": [
            {
              "id": "eng-verb-1",
              "title": "The doing word — what is a verb?",
              "type": "story",
              "character": "lila",
              "story": "Lila flaps her wings! FLAPS is a verb — it tells us what Lila does. A VERB is a doing word. It tells us what someone or something does. Run, jump, eat, sleep, read, fly — these are all verbs!",
              "game": {
                "type": "sorting",
                "question": "Which words are VERBS (doing words)?",
                "categories": ["Verb (doing word)", "Not a verb"],
                "items": [
                  { "name": "swim", "category": 0 },
                  { "name": "beautiful", "category": 1 },
                  { "name": "climb", "category": 0 },
                  { "name": "table", "category": 1 },
                  { "name": "write", "category": 0 },
                  { "name": "quickly", "category": 1 }
                ],
                "hint": "Verbs are action words — they tell us what someone DOES!"
              },
              "quiz": [
                { "q": "Which word is a verb?", "options": ["elephant","beautiful","roar","forest"], "correct": 2 },
                { "q": "A verb tells us ______.", "options": ["a name","a place","what someone does","a colour"], "correct": 2 },
                { "q": "In 'The bird sings.' — the verb is ______.", "options": ["The","bird","sings","None"], "correct": 2 }
              ],
              "rewards": { "stars": 3, "coins": 12, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-adjective",
      "title": "The Adjective",
      "emoji": "🌈",
      "term": "first",
      "month": "July",
      "skills": [
        {
          "id": "eng-adj-describing",
          "title": "Describing words",
          "lessons": [
            {
              "id": "eng-adj-1",
              "title": "Words that describe — adjectives",
              "type": "story",
              "character": "lila",
              "story": "Lila lives in a TALL, GREEN, beautiful tree! TALL, GREEN and BEAUTIFUL are adjectives. An ADJECTIVE is a describing word. It tells us more about a noun — its colour, size, shape or type. 'The big, red apple.' — big and red are adjectives!",
              "game": {
                "type": "drag_match",
                "question": "Match each noun to the best adjective!",
                "pairs": [
                  { "item": "elephant", "match": "huge" },
                  { "item": "lemon", "match": "sour" },
                  { "item": "ice", "match": "cold" },
                  { "item": "feather", "match": "light" }
                ],
                "hint": "Adjectives describe how something looks, feels, tastes or smells!"
              },
              "quiz": [
                { "q": "Which word is an adjective?", "options": ["run","slowly","beautiful","sing"], "correct": 2 },
                { "q": "An adjective describes a ______.", "options": ["verb","adjective","noun","sentence"], "correct": 2 },
                { "q": "In 'She has a red bag.' — red is ______.", "options": ["a noun","a verb","an adjective","an adverb"], "correct": 2 }
              ],
              "rewards": { "stars": 3, "coins": 12, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-pronoun",
      "title": "The Pronoun",
      "emoji": "👤",
      "term": "first",
      "month": "August",
      "skills": [
        {
          "id": "eng-pronoun-basic",
          "title": "Words that replace nouns",
          "lessons": [
            {
              "id": "eng-pronoun-1",
              "title": "He, she, they — pronouns!",
              "type": "story",
              "character": "lila",
              "story": "Lila said: 'Lila loves reading. Lila reads every day. Lila has many books.' That sounds repetitive! Instead we say: 'Lila loves reading. SHE reads every day. SHE has many books.' SHE is a pronoun! A PRONOUN takes the place of a noun.",
              "game": {
                "type": "tap_correct",
                "question": "Replace 'Riya and Meena' with the correct pronoun: '______ are best friends.'",
                "options": ["He", "She", "They", "It"],
                "correct": 2,
                "hint": "Use 'they' for more than one person!"
              },
              "quiz": [
                { "q": "Replace 'The book' with a pronoun: '______ is on the table.'", "options": ["He","She","They","It"], "correct": 3 },
                { "q": "Which word is a pronoun?", "options": ["cat","run","we","blue"], "correct": 2 },
                { "q": "A pronoun takes the place of a ______.", "options": ["verb","noun","adjective","sentence"], "correct": 1 }
              ],
              "rewards": { "stars": 3, "coins": 12, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-adverb",
      "title": "The Adverb",
      "emoji": "⚡",
      "term": "first",
      "month": "August",
      "skills": [
        {
          "id": "eng-adverb-basic",
          "title": "Words that describe verbs",
          "lessons": [
            {
              "id": "eng-adverb-1",
              "title": "How, when, where — adverbs!",
              "type": "story",
              "character": "lila",
              "story": "Lila reads QUICKLY. She reads HERE every day. She ALWAYS reads in the morning. QUICKLY, HERE and ALWAYS are adverbs! An ADVERB tells us more about a verb. It says HOW (quickly), WHERE (here) or WHEN (always) the action happens.",
              "game": {
                "type": "drag_match",
                "question": "Match the verb to the adverb that goes with it!",
                "pairs": [
                  { "item": "She sings ______.", "match": "loudly" },
                  { "item": "He ran ______.", "match": "quickly" },
                  { "item": "They arrived ______.", "match": "early" },
                  { "item": "She speaks ______.", "match": "softly" }
                ],
                "hint": "Adverbs often end in -ly!"
              },
              "quiz": [
                { "q": "In 'He speaks clearly.' — 'clearly' is ______.", "options": ["a noun","a verb","an adjective","an adverb"], "correct": 3 },
                { "q": "An adverb tells us more about a ______.", "options": ["noun","verb","adjective","pronoun"], "correct": 1 },
                { "q": "Which word is an adverb?", "options": ["beautiful","gently","flower","run"], "correct": 1 }
              ],
              "rewards": { "stars": 4, "coins": 15, "badge": "grammar_star" }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-articles",
      "title": "Articles",
      "emoji": "📌",
      "term": "final",
      "month": "October",
      "skills": [
        {
          "id": "eng-articles-basic",
          "title": "A, An, The",
          "lessons": [
            {
              "id": "eng-articles-1",
              "title": "A, An and The — the little helpers!",
              "type": "story",
              "character": "lila",
              "story": "Lila says: 'A, An and The are ARTICLES!' Use A before consonant sounds: a cat, a book. Use AN before vowel sounds: an apple, an orange, an umbrella. Use THE for a specific thing: THE book on my shelf (that particular book).",
              "game": {
                "type": "tap_correct",
                "question": "Choose the correct article: '______ elephant is big.'",
                "options": ["A", "An", "The", "No article"],
                "correct": 1,
                "hint": "'Elephant' starts with a vowel sound — use AN!"
              },
              "quiz": [
                { "q": "______ apple a day keeps the doctor away.", "options": ["A","An","The","Some"], "correct": 1 },
                { "q": "She is reading ______ interesting book.", "options": ["a","an","the","—"], "correct": 1 },
                { "q": "______ Taj Mahal is in Agra.", "options": ["A","An","The","—"], "correct": 2 }
              ],
              "rewards": { "stars": 3, "coins": 15, "badge": null }
            }
          ]
        }
      ]
    },
    {
      "id": "eng-tense",
      "title": "Tenses",
      "emoji": "⏰",
      "term": "final",
      "month": "November",
      "skills": [
        {
          "id": "eng-tense-present",
          "title": "Simple Present and Present Continuous",
          "lessons": [
            {
              "id": "eng-tense-1",
              "title": "Present tense — happening now!",
              "type": "story",
              "character": "lila",
              "story": "Lila READS every day. (Simple Present — habit/fact)\nLila IS READING right now. (Present Continuous — happening at this moment!)\nSimple Present: He plays. She runs.\nPresent Continuous: He is playing. She is running. We add -ing!",
              "game": {
                "type": "tap_correct",
                "question": "Which sentence uses Present Continuous tense?",
                "options": ["She dances every evening.", "She is dancing now.", "She danced yesterday.", "She will dance tomorrow."],
                "correct": 1,
                "hint": "Present Continuous uses 'is/am/are + verb+ing'!"
              },
              "quiz": [
                { "q": "Change to Present Continuous: 'He reads.'", "options": ["He read.","He is reading.","He was reading.","He reads now."], "correct": 1 },
                { "q": "In Simple Present, we add ___ for he/she/it.", "options": ["-ing","-ed","-s or -es","nothing"], "correct": 2 },
                { "q": "Which is Simple Present?", "options": ["They are playing.","They played.","They play cricket.","They will play."], "correct": 2 }
              ],
              "rewards": { "stars": 4, "coins": 20, "badge": "tense_master" }
            }
          ]
        }
      ]
    }
  ]
}
